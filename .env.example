# Django Configuration
SECRET_KEY=your-secret-key-change-this-in-production-please
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=rrhh_db
DB_USER=postgres
DB_PASSWORD=postgres123
DB_HOST=localhost
DB_PORT=5432

# Email (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=usuario@gmail.com
EMAIL_HOST_PASSWORD=password
DEFAULT_FROM_EMAIL=sistema@institucion.gov.py

# GIS
GDAL_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu/libgdal.so

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Google Maps API Key para croquis satelital
GOOGLE_MAPS_API_KEY=


# LDAP / Active Directory
ENABLE_LDAP_AUTH=False
AUTH_LDAP_SERVER_URI=ldaps://IP_LDAP
AUTH_LDAP_DOMAIN=DOMAIN.LOCAL
AUTH_LDAP_SEARCH_BASE=DC=DC,DC=local
AUTH_LDAP_BIND_DN=DC/DC
AUTH_LDAP_BIND_PASSWORD=PASSSWORD
AUTH_LDAP_DISABLE_CERT_CHECK=True
